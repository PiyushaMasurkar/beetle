<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="six_wheel_rover">

  <!-- <xacro:include filename="camera.xacro"/> -->
  <xacro:include filename="lidar.xacro"/>
  <xacro:include filename="inertial_macros.xacro"/>
  <xacro:include filename="depth_camera.xacro"/>

  <!-- PARAMETERS -->
  <xacro:property name="wheel_radius" value="0.09"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_x" value="0.30"/>
  <xacro:property name="wheel_y" value="0.28"/>
  <xacro:property name="chassis_height" value="0.15"/>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- BASE LINK -->
  
  <link name="base_link">
    
  </link>

  <!-- BASE_FOOTPRINT LINK -->
  <link name="base_footprint">

  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <!-- CHASSIS LINK -->
  <link name="chassis">

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="25"/>
      <inertia ixx="1.2" iyy="1.5" izz="2.0"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 ${wheel_radius + chassis_height/2}"/>
      <geometry>
        <box size="0.7 0.5 ${chassis_height}"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 ${wheel_radius + chassis_height/2}"/>
      <geometry>
        <box size="0.7 0.5 ${chassis_height}"/>
      </geometry>
    </collision>

  </link>

  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- WHEEL MACRO -->
  <xacro:macro name="wheel" params="name x y">

    <link name="${name}">

      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="2"/>
        <inertia ixx="0.02" iyy="0.02" izz="0.02"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>

      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

    </link>

    <joint name="${name}_joint" type="continuous">

      <parent link="base_link"/>
      <child link="${name}"/>

      <origin xyz="${x} ${y} ${wheel_radius}"/>

      <axis xyz="0 1 0"/>

      <limit effort="50" velocity="20"/>

    </joint>

  </xacro:macro>

  <!-- LEFT SIDE -->
  <xacro:wheel name="left_front_wheel" x="${wheel_x}" y="${wheel_y}"/>
  <xacro:wheel name="left_mid_wheel" x="0" y="${wheel_y}"/>
  <xacro:wheel name="left_rear_wheel" x="-${wheel_x}" y="${wheel_y}"/>

  <!-- RIGHT SIDE -->
  <xacro:wheel name="right_front_wheel" x="${wheel_x}" y="-${wheel_y}"/>
  <xacro:wheel name="right_mid_wheel" x="0" y="-${wheel_y}"/>
  <xacro:wheel name="right_rear_wheel" x="-${wheel_x}" y="-${wheel_y}"/>

  <!-- FRICTION SETTINGS -->

  <!-- FRONT WHEELS SLIDE -->
  <gazebo reference="left_front_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="right_front_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- REAR WHEELS SLIDE -->
  <gazebo reference="left_rear_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="right_rear_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- MIDDLE WHEELS DRIVE -->
  <gazebo reference="left_mid_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <gazebo reference="right_mid_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <!-- DIFFERENTIAL DRIVE -->
  <gazebo>
  <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

    <left_joint>left_mid_wheel_joint</left_joint>
    <right_joint>right_mid_wheel_joint</right_joint>

    <wheel_separation>0.56</wheel_separation>
    <wheel_diameter>0.18</wheel_diameter>

    <publish_odom>true</publish_odom>
    <publish_odom_tf>true</publish_odom_tf>

    <odometry_frame>odom</odometry_frame>
    <robot_base_frame>base_link</robot_base_frame>

  </plugin>
</gazebo>

</robot>